{
  "singleQuote": true,
  "trailingComma": "none",
  "printWidth": 100,
  "tabWidth": 4,
  "useTabs": false,
  "semi": true,
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "overrides": [
    {
      "files": ["*.html"],
      "options": {
        "printWidth": 120,
        "parser": "html"
      }
    },
    {
      "files": ["*.css"],
      "options": {
        "printWidth": 100,
        "parser": "css"
      }
    }
  ]
}
