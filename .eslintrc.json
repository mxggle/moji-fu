{
    "root": true,
    "env": {
        "browser": true,
        "es2022": true,
        "webextensions": true,
        "node": true
    },
    "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "script"
    },
    "extends": ["prettier"],
    "rules": {
        "linebreak-style": ["error", "unix"],
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
        "no-console": "off",
        "eqeqeq": ["error", "always"],
        "no-shadow": "warn",
        "no-use-before-define": ["warn", { "functions": false, "classes": false }],
        "no-unused-expressions": "warn",
        "no-undef": "error"
    },
    "globals": {
        "chrome": "readonly",
        "MojiFuStorage": "readonly"
    },
    "ignorePatterns": ["node_modules/", "*.zip"]
}
